<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Soft sakura pink gradient -->
    <gradient
        android:startColor="#FBE1EA"
        android:endColor="#F5B7C8"
        android:angle="270" />

    <!-- Rounded corners -->
    <corners android:radius="24dp" />

    <!-- Optional soft stroke -->
    <stroke
        android:width="1dp"
        android:color="#F2AFC2" />

    <!-- Padding inside the button -->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp" />

</shape>