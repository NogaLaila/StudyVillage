<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgSeaBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/bg_village_sea"
        android:scaleType="centerCrop"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:id="@+id/bgDim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#0D000000"
        app:layout_constraintTop_toTopOf="@id/imgSeaBg"
        app:layout_constraintBottom_toBottomOf="@id/imgSeaBg"
        app:layout_constraintStart_toStartOf="@id/imgSeaBg"
        app:layout_constraintEnd_toEndOf="@id/imgSeaBg"/>

    <ImageView
        android:id="@+id/imgIsland"
        android:layout_width="463dp"
        android:layout_height="677dp"
        android:layout_marginBottom="144dp"
        android:adjustViewBounds="true"
        android:importantForAccessibility="no"
        android:scaleType="fitCenter"
        android:src="@drawable/bg_village_island"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.90"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ✅ Tap catcher FIRST (below placedLayer) -->
    <View
        android:id="@+id/islandTapLayer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="@id/imgIsland"
        app:layout_constraintBottom_toBottomOf="@id/imgIsland"
        app:layout_constraintStart_toStartOf="@id/imgIsland"
        app:layout_constraintEnd_toEndOf="@id/imgIsland"/>

    <!-- ✅ Placed items SECOND (on top, clickable) -->
    <FrameLayout
        android:id="@+id/placedLayer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="@id/imgIsland"
        app:layout_constraintBottom_toBottomOf="@id/imgIsland"
        app:layout_constraintStart_toStartOf="@id/imgIsland"
        app:layout_constraintEnd_toEndOf="@id/imgIsland"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="2dp"
        app:cardUseCompatPadding="true"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/imgTopBarBg"
                android:layout_width="600dp"
                android:layout_height="440dp"
                android:src="@drawable/bg_title_bar"
                android:scaleType="fitXY"
                android:importantForAccessibility="no"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/txtTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Village"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/txtCoins"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <ImageView
                    android:id="@+id/imgCoin"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="6dp"
                    android:src="@drawable/ic_coin"
                    android:contentDescription="Coins"
                    app:layout_constraintEnd_toStartOf="@id/txtCoins"
                    app:layout_constraintTop_toTopOf="@id/txtCoins"
                    app:layout_constraintBottom_toBottomOf="@id/txtCoins"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPlace"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="Inventory"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_margin="16dp"
        android:paddingStart="14dp"
        android:paddingEnd="16dp"

        app:icon="@android:drawable/ic_menu_agenda"
        app:iconPadding="8dp"
        app:iconTint="#000000"
        app:iconSize="22dp"

        app:backgroundTint="#FFE8A8"
        app:cornerRadius="20dp"
        app:elevation="3dp"

        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>