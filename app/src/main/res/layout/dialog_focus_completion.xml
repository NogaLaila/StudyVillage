<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="20dp"
    android:paddingEnd="24dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/tvRewardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/focus_reward_title"
        android:textColor="#3E2E2A"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRewardSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/focus_reward_subtitle"
        android:textColor="#8B7B75"
        android:textSize="24sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@string/focus_coins"
            android:src="@drawable/ic_coin" />

        <TextView
            android:id="@+id/tvRewardCoins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text=""
            android:textColor="#3E2E2A"
            android:textSize="42sp"
            android:textStyle="bold"
            tools:text="25" />
    </LinearLayout>

</LinearLayout>


