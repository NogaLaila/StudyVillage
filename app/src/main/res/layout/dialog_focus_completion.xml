<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_focus_completion_card"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_focus_leaf_dot" />

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_focus_leaf_dot" />

        <TextView
            android:id="@+id/tvRewardTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:text="@string/focus_reward_title"
            android:textColor="#3E2E2A"
            android:textSize="32sp"
            android:textStyle="bold" />

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_focus_leaf_dot" />

        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_focus_leaf_dot" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvRewardSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/focus_reward_subtitle"
        android:textColor="#8B7B75"
        android:textSize="24sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_focus_completion_coin_badge"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:contentDescription="@string/focus_coins"
                android:src="@drawable/ic_coin" />

            <TextView
                android:id="@+id/tvRewardCoins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textColor="#3E2E2A"
                android:textSize="42sp"
                android:textStyle="bold"
                tools:text="25" />
        </LinearLayout>
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRewardClose"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_focus_button_sakura"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="@string/focus_reward_close"
        android:textAllCaps="false"
        android:textColor="#3E2E2A"
        android:textSize="20sp"
        android:textStyle="bold"
        app:backgroundTint="@null" />

</LinearLayout>


