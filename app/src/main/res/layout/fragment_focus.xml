<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgFocusBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        android:src="@drawable/timer_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/tvFocusTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/focus_title"
        android:textAllCaps="true"
        android:textColor="#3E2E2A"
        android:textSize="40sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/focusPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="#FDFDFD"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/statsPill"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvFocusTitle"
        app:layout_constraintVertical_bias="0.2">

        <TextView
            android:id="@+id/tvTimeRemaining"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:background="@drawable/bg_focus_timer_pill"
            android:gravity="center"
            android:text="25:00"
            android:textColor="#3E2E2A"
            android:textSize="52sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/intervalRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="3">

            <EditText
                android:id="@+id/etIntervalMinutes"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="2"
                android:background="@drawable/bg_focus_timer_pill"
                android:gravity="center"
                android:hint="25"
                android:imeOptions="actionDone"
                android:inputType="number"
                android:maxLength="3"
                android:textColor="#3E2E2A"
                android:textColorHint="#8B7B75"
                android:textSize="24sp"
                tools:text="25" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSetInterval"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:background="@drawable/bg_focus_button_green"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/focus_set_time"
                android:textAllCaps="true"
                android:textColor="#3E2E2A"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/buttonsColumn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_focus_button_green"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/focus_start"
                android:textAllCaps="true"
                android:textColor="#3E2E2A"
                android:textSize="24sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPause"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_focus_button_peach"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/focus_pause"
                android:textAllCaps="true"
                android:textColor="#3E2E2A"
                android:textSize="24sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_focus_button_peach"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/focus_reset"
                android:textAllCaps="true"
                android:textColor="#3E2E2A"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/statsPill"
        android:layout_width="220dp"
        android:layout_height="54dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/bg_focus_stats_pill"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/focus_coins"
            android:src="@drawable/ic_coin" />

        <TextView
            android:id="@+id/tvCoins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="45"
            android:textColor="#3E2E2A"
            android:textSize="28sp"
            android:textStyle="bold" />

        <View
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <View
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@drawable/bg_focus_leaf_dot" />

        <TextView
            android:id="@+id/tvLives"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="2"
            android:textColor="#3E2E2A"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
