<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_focus_screen">

    <TextView
        android:id="@+id/tvFocusTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/focus_title"
        android:textAllCaps="true"
        android:textColor="#3E2E2A"
        android:textSize="40sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgIsland"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:adjustViewBounds="true"
        android:importantForAccessibility="no"
        android:scaleType="fitCenter"
        android:src="@drawable/bg_village_island_full"
        app:layout_constraintBottom_toTopOf="@id/timerBubble"
        app:layout_constraintDimensionRatio="1:1.15"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvFocusTitle"
        app:layout_constraintWidth_percent="0.98" />

    <ImageView
        android:id="@+id/imgPanda"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:importantForAccessibility="no"
        android:scaleType="fitCenter"
        android:src="@drawable/baker_panda"
        app:layout_constraintBottom_toBottomOf="@id/imgIsland"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="@id/imgIsland"
        app:layout_constraintStart_toStartOf="@id/imgIsland"
        app:layout_constraintTop_toTopOf="@id/imgIsland"
        app:layout_constraintVertical_bias="0.06"
        app:layout_constraintWidth_percent="0.52" />

    <TextView
        android:id="@+id/tvTimeRemaining"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        android:background="@drawable/bg_focus_timer_pill"
        android:gravity="center"
        android:text="25:00"
        android:textColor="#3E2E2A"
        android:textSize="52sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgIsland" />

    <LinearLayout
        android:id="@+id/buttonsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/timerBubble">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkip"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focus_button_peach"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/focus_skip"
            android:textAllCaps="true"
            android:textColor="#3E2E2A"
            android:textSize="24sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPause"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focus_button_peach"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/focus_pause"
            android:textAllCaps="true"
            android:textColor="#3E2E2A"
            android:textSize="24sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_focus_button_green"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/focus_start"
            android:textAllCaps="true"
            android:textColor="#3E2E2A"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/statsPill"
        android:layout_width="220dp"
        android:layout_height="54dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_focus_stats_pill"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonsRow">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/focus_coins"
            android:src="@drawable/ic_coin" />

        <TextView
            android:id="@+id/tvCoins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="45"
            android:textColor="#3E2E2A"
            android:textSize="28sp"
            android:textStyle="bold" />

        <View
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <View
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@drawable/bg_focus_leaf_dot" />

        <TextView
            android:id="@+id/tvLives"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="2"
            android:textColor="#3E2E2A"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/bottomGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.93" />

    <View
        android:id="@+id/timerBubble"
        android:layout_width="0dp"
        android:layout_height="1dp"
        app:layout_constraintTop_toTopOf="@id/tvTimeRemaining"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
